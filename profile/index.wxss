.user-card {
  padding: 40rpx 30rpx;
  background: var(--white);
  margin-bottom: 20rpx;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  background: #eee;
  border-radius: 50%;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  margin-bottom: 8rpx;
  font-weight: bold;
}

.stats-grid {
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.stat-item {
  width: 33%;
}

.stat-num {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-main);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.menu-list {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

.menu-item {
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  margin-right: 20rpx;
  font-size: 32rpx;
}

.arrow {
  color: var(--text-light);
  font-size: 24rpx;
}
