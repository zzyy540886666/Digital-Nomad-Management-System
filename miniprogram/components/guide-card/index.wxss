.guide-card {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.icon-wrapper .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.icon-wrapper.network {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
}

.icon-wrapper.transport {
  background: linear-gradient(135deg, #52c41a 0%, #3da00f 100%);
}

.icon-wrapper.medical {
  background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
}

.icon-wrapper.food {
  background: linear-gradient(135deg, #faad14 0%, #d48806 100%);
}

.icon-wrapper.cowork {
  background: linear-gradient(135deg, #722ed1 0%, #531dab 100%);
}

.icon-wrapper.stay {
  background: linear-gradient(135deg, #13c2c2 0%, #08979c 100%);
}

.name {
  font-size: 24rpx;
  color: #333;
}
