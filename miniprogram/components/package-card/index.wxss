.package-card {
  display: flex;
  background-color: #fff;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.package-card:last-child {
  border-bottom: none;
}

.cover {
  width: 200rpx;
  height: 150rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.content {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tags {
  margin-top: 12rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  background-color: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
  font-size: 20rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.footer {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-top: 12rpx;
}

.price {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 24rpx;
  color: #ff4d4f;
}

.price-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.price-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}

.reason {
  display: flex;
  align-items: center;
  background-color: #fff7e6;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
}

.reason-icon {
  font-size: 20rpx;
  color: #faad14;
  margin-right: 6rpx;
}

.reason-text {
  font-size: 22rpx;
  color: #faad14;
}
