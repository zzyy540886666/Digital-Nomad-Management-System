<view class="search-page">
  <view class="search-header">
    <view class="search-input-wrap">
      <image class="search-icon" src="{{searchIconUrl}}" mode="aspectFit"></image>
      <input 
        class="search-input" 
        placeholder="搜索旅居包/活动/技能" 
        value="{{keyword}}"
        bindinput="onInput"
        bindconfirm="onSearch"
        focus="{{true}}"
      />
      <image wx:if="{{keyword}}" class="clear-icon" src="{{closeIconUrl}}" mode="aspectFit" bindtap="onClear"></image>
    </view>
    <view class="search-btn" bindtap="onSearch">搜索</view>
  </view>

  <view wx:if="{{!hasSearched}}" class="search-content">
    <view wx:if="{{history.length > 0}}" class="section">
      <view class="section-header">
        <text class="section-title">搜索历史</text>
        <text class="clear-text" bindtap="clearHistory">清空</text>
      </view>
      <view class="tag-list">
        <view class="tag" wx:for="{{history}}" wx:key="*this" bindtap="onTagTap" data-keyword="{{item}}">{{item}}</view>
      </view>
    </view>

    <view class="section">
      <view class="section-header">
        <text class="section-title">热门搜索</text>
      </view>
      <view class="tag-list">
        <view class="tag" wx:for="{{hotKeywords}}" wx:key="*this" bindtap="onTagTap" data-keyword="{{item}}">{{item}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{hasSearched}}" class="search-results">
    <view wx:if="{{searching}}" class="loading-state">
      <view class="loading-spinner"></view>
      <text>搜索中...</text>
    </view>

    <view wx:elif="{{results.packages.length === 0 && results.events.length === 0 && results.posts.length === 0}}" class="empty-state">
      <text>未找到相关结果</text>
    </view>

    <block wx:else>
      <view wx:if="{{results.packages.length > 0}}" class="result-section">
        <view class="result-title">旅居包 ({{results.packages.length}})</view>
        <view class="result-item" wx:for="{{results.packages}}" wx:key="id" bindtap="onPackageDetail" data-id="{{item.id}}">
          <image class="result-cover" src="{{item.coverUrl}}" mode="aspectFill"></image>
          <view class="result-info">
            <text class="result-name">{{item.title}}</text>
            <text class="result-price">{{item.priceMin}}起</text>
          </view>
          <image class="result-arrow" src="{{arrowRightUrl}}" mode="aspectFit"></image>
        </view>
      </view>

      <view wx:if="{{results.events.length > 0}}" class="result-section">
        <view class="result-title">活动 ({{results.events.length}})</view>
        <view class="result-item" wx:for="{{results.events}}" wx:key="id" bindtap="onEventDetail" data-id="{{item.id}}">
          <image class="result-cover" src="{{item.coverUrl}}" mode="aspectFill"></image>
          <view class="result-info">
            <text class="result-name">{{item.title}}</text>
            <text class="result-meta">{{item.startTime}} | {{item.venueName}}</text>
          </view>
          <image class="result-arrow" src="{{arrowRightUrl}}" mode="aspectFit"></image>
        </view>
      </view>

      <view wx:if="{{results.posts.length > 0}}" class="result-section">
        <view class="result-title">技能交换 ({{results.posts.length}})</view>
        <view class="result-item" wx:for="{{results.posts}}" wx:key="id" bindtap="onPostDetail" data-id="{{item.id}}">
          <view class="result-info">
            <text class="result-name">{{item.title}}</text>
            <text class="result-meta">{{item.userNickname}} | {{item.createdAt}}</text>
          </view>
          <image class="result-arrow" src="{{arrowRightUrl}}" mode="aspectFit"></image>
        </view>
      </view>
    </block>
  </view>
</view>
