.matches-page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.tabs {
  display: flex;
  background-color: #fff;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #666;
}

.tab-item.active {
  color: #4A90D9;
  font-weight: bold;
}

.match-list {
  padding: 24rpx;
}

.match-item {
  display: flex;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.content { flex: 1; }

.header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.nickname {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.status-tag {
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
}

.status-tag.sent { background-color: rgba(250, 173, 20, 0.1); color: #faad14; }
.status-tag.accepted { background-color: rgba(82, 196, 26, 0.1); color: #52c41a; }

.post-title, .message {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.time {
  font-size: 22rpx;
  color: #999;
}

.actions {
  display: flex;
  flex-direction: column;
  justify-content: center;
  margin-left: 16rpx;
}

.action-btn {
  padding: 12rpx 20rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  text-align: center;
  margin-bottom: 10rpx;
}

.action-btn.accept { background-color: #4A90D9; color: #fff; }
.action-btn.reject { background-color: #f5f5f5; color: #666; }
