.posts-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 24rpx;
}

.post-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.post-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.type-tag, .status-tag {
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
}

.type-tag.offer { background-color: rgba(74, 144, 217, 0.1); color: #4A90D9; }
.type-tag.need { background-color: rgba(114, 46, 209, 0.1); color: #722ed1; }
.type-tag.project { background-color: rgba(250, 173, 20, 0.1); color: #faad14; }
.status-tag.pending { background-color: rgba(250, 173, 20, 0.1); color: #faad14; }
.status-tag.approved { background-color: rgba(82, 196, 26, 0.1); color: #52c41a; }

.post-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.create-time {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 12rpx;
}
