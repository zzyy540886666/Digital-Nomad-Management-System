.settings-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.section {
  background-color: #fff;
  margin-bottom: 24rpx;
  padding: 0 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  padding: 24rpx 0 16rpx;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  flex-shrink: 0;
}

.form-input {
  flex: 1;
  font-size: 28rpx;
  text-align: right;
}

.form-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  text-align: right;
}

.tags-input {
  display: flex;
  flex-wrap: wrap;
  padding-bottom: 20rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: rgba(74, 144, 217, 0.1);
  border-radius: 6rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.tag-item text:first-child {
  font-size: 26rpx;
  color: #4A90D9;
}

.tag-item .remove {
  margin-left: 10rpx;
  color: #999;
  font-size: 32rpx;
}

.tag-input {
  min-width: 120rpx;
  font-size: 26rpx;
  padding: 10rpx 0;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  font-size: 28rpx;
  color: #333;
}

.menu-item .icon-arrow-right {
  font-size: 28rpx;
  color: #ccc;
}

.menu-item.logout {
  justify-content: center;
}

.menu-item.logout .menu-text {
  color: #ff4d4f;
}

.save-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
}

.save-btn {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  font-size: 32rpx;
  border-radius: 40rpx;
  height: 88rpx;
  line-height: 88rpx;
}
