.event-list-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 120rpx;
}

.header {
  background: #fff;
  padding: 20rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  border-bottom: 1rpx solid #f0f0f0;
}

.search-bar {
  background-color: #f5f7fa;
  border-radius: 40rpx;
  padding: 18rpx 28rpx;
  display: flex;
  align-items: center;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
  opacity: 0.6;
}

.placeholder {
  color: #999;
  font-size: 28rpx;
}

.filters {
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
  border-bottom: 1rpx solid #f0f0f0;
}

.category-scroll {
  white-space: nowrap;
  padding: 20rpx 24rpx;
}

.category-item {
  display: inline-block;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #f5f7fa;
  border-radius: 30rpx;
  margin-right: 16rpx;
  transition: all 0.2s;
}

.category-item.active {
  background: #4A90D9;
  color: #fff;
}

.list-content {
  padding: 20rpx 24rpx;
}

.event-card {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s, box-shadow 0.2s;
}

.event-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.card-cover {
  width: 100%;
  height: 280rpx;
  background-color: #f0f0f0;
}

.card-body {
  padding: 24rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.4;
  margin-right: 16rpx;
}

.status-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.status-tag.free {
  color: #1890ff;
  background-color: rgba(24, 144, 255, 0.1);
}

.status-tag.paid {
  color: #fa8c16;
  background-color: rgba(250, 140, 22, 0.1);
}

.card-meta {
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.meta-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 10rpx;
  opacity: 0.5;
}

.meta-item text {
  font-size: 26rpx;
  color: #888;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.organizer {
  display: flex;
  align-items: center;
}

.avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  margin-right: 12rpx;
}

.organizer-name {
  font-size: 24rpx;
  color: #666;
}

.signup-info {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.signup-count {
  font-size: 24rpx;
  color: #52c41a;
  margin-bottom: 8rpx;
}

.capacity-bar {
  width: 120rpx;
  height: 8rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.capacity-fill {
  height: 100%;
  background: linear-gradient(90deg, #52c41a 0%, #389e0d 100%);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #52c41a;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading text {
  color: #999;
  font-size: 26rpx;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-state text {
  color: #999;
  font-size: 28rpx;
}