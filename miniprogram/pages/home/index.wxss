.home-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 140rpx;
}

.header {
  background: #fff;
  padding: 0 30rpx 30rpx;
  padding-top: calc(20rpx + env(safe-area-inset-top));
  border-bottom: 1rpx solid #f0f0f0;
}

.header-top {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
}

.location {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx 8rpx 8rpx;
  background: #f5f7fa;
  border-radius: 32rpx;
  margin-right: 20rpx;
}

.location-icon {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
}

.location .city {
  color: #333;
  font-size: 28rpx;
  font-weight: 600;
  margin: 0 6rpx;
}

.arrow-icon {
  width: 24rpx;
  height: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-bar {
  flex: 1;
  background-color: #f5f7fa;
  border-radius: 40rpx;
  padding: 18rpx 28rpx;
  display: flex;
  align-items: center;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.search-bar .placeholder {
  color: #999;
  font-size: 28rpx;
}

/* 轮播图样式 */
.banner-section {
  margin: 24rpx 24rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.banner-swiper {
  width: 100%;
  height: 320rpx;
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 30rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, rgba(0,0,0,0) 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

/* 快捷入口样式 */
.quick-entry {
  display: flex;
  justify-content: space-around;
  background-color: #fff;
  padding: 32rpx 20rpx;
  margin: 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.entry-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.2s;
}

.entry-item:active {
  transform: scale(0.95);
}

.entry-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.entry-text {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

.section {
  padding: 0 24rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 8rpx 20rpx;
}

.section-title-wrap {
  display: flex;
  flex-direction: column;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #888;
  padding: 8rpx 0;
}

.section-more text {
  margin-right: 4rpx;
}

.more-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.6;
}

.package-scroll {
  display: flex;
  gap: 20rpx;
  overflow-x: auto;
  padding: 8rpx 0 16rpx;
  -webkit-overflow-scrolling: touch;
}

.package-scroll::-webkit-scrollbar {
  display: none;
}

.package-card {
  flex-shrink: 0;
  width: 320rpx;
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s, box-shadow 0.2s;
}

.package-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.package-cover {
  width: 100%;
  height: 200rpx;
  background-color: #f0f0f0;
}

.package-info {
  padding: 20rpx;
}

.package-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
  min-height: 78rpx;
}

.package-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.package-tags .tag {
  font-size: 20rpx;
  color: #4A90D9;
  background-color: rgba(74, 144, 217, 0.1);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.package-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.price {
  display: flex;
  align-items: baseline;
}

.price-symbol {
  font-size: 24rpx;
  color: #FF6B35;
  font-weight: 600;
}

.price-value {
  font-size: 36rpx;
  color: #FF6B35;
  font-weight: 700;
}

.price-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 4rpx;
}

.reason {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #FFF7E6 0%, #FFEDD5 100%);
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
}

.reason-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 6rpx;
}

.reason-text {
  font-size: 20rpx;
  color: #D97706;
  font-weight: 500;
}

.event-list {
  background-color: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.event-card {
  display: flex;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  transition: background-color 0.2s;
}

.event-card:last-child {
  border-bottom: none;
}

.event-card:active {
  background-color: #fafafa;
}

.event-cover {
  width: 180rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background-color: #f0f0f0;
  flex-shrink: 0;
}

.event-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.event-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.4;
}

.event-meta {
  margin-top: 12rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.meta-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  opacity: 0.6;
}

.meta-item text {
  font-size: 24rpx;
  color: #888;
}

.event-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.event-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.status-tag.free {
  color: #52c41a;
  background-color: rgba(82, 196, 26, 0.1);
}

.status-tag.paid {
  color: #4A90D9;
  background-color: rgba(74, 144, 217, 0.1);
}

.capacity {
  font-size: 22rpx;
  color: #999;
}

.guide-grid {
  display: flex;
  flex-wrap: wrap;
  background-color: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.guide-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
  transition: transform 0.2s;
}

.guide-item:active {
  transform: scale(0.95);
}

.guide-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

.guide-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}

.community-section {
  margin-bottom: 32rpx;
}

.community-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #E6F4FF;
}

.community-content {
  flex: 1;
}

.community-title {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.community-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.community-title text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.community-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

.arrow-right-icon {
  width: 40rpx;
  height: 40rpx;
  opacity: 0.4;
}

.post-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.post-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.post-type {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.post-type.offer {
  background: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
}

.post-type.seek {
  background: rgba(250, 140, 22, 0.1);
  color: #fa8c16;
}

.post-time {
  font-size: 22rpx;
  color: #999;
}

.post-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.post-tag {
  font-size: 22rpx;
  color: #666;
  background: #f5f7fa;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.floating-btn {
  position: fixed;
  right: 30rpx;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  width: 108rpx;
  height: 108rpx;
  background: linear-gradient(135deg, #4A90D9 0%, #2E6DB4 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.4);
  transition: transform 0.2s, box-shadow 0.2s;
  z-index: 100;
}

.floating-btn:active {
  transform: scale(0.95);
}

.floating-icon {
  width: 52rpx;
  height: 52rpx;
}

.empty-state {
  padding: 80rpx 0;
  text-align: center;
}

.empty-state text {
  color: #999;
  font-size: 28rpx;
}

.bg-success {
  background-color: #52c41a;
}

.bg-warning {
  background-color: #faad14;
}

.bg-danger {
  background-color: #ff4d4f;
}
