.package-detail-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.banner {
  width: 100%;
  height: 400rpx;
}

.banner image {
  width: 100%;
  height: 100%;
}

.main-info {
  background-color: #fff;
  padding: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}

.tags {
  margin-top: 16rpx;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background-color: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
  font-size: 22rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
}

.price-row {
  margin-top: 20rpx;
}

.price {
  display: flex;
  align-items: baseline;
}

.price .label {
  font-size: 28rpx;
  color: #ff4d4f;
}

.price .value {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.price .unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 4rpx;
}

.price .original {
  font-size: 26rpx;
  color: #999;
  text-decoration: line-through;
  margin-left: 12rpx;
}

.section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.items-list {
  display: flex;
  flex-direction: column;
}

.item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.item:last-child {
  border-bottom: none;
}

.item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.item-icon .iconfont {
  font-size: 40rpx;
  color: #fff;
}

.item-icon.stay {
  background: linear-gradient(135deg, #13c2c2 0%, #08979c 100%);
}

.item-icon.cowork {
  background: linear-gradient(135deg, #722ed1 0%, #531dab 100%);
}

.item-icon.service {
  background: linear-gradient(135deg, #faad14 0%, #d48806 100%);
}

.item-content {
  flex: 1;
}

.item-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.item-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
}

.optional-list {
  display: flex;
  flex-direction: column;
}

.optional-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.optional-item:last-child {
  border-bottom: none;
}

.optional-name {
  font-size: 28rpx;
  color: #333;
}

.optional-price {
  font-size: 28rpx;
  color: #ff4d4f;
}

.price-info,
.notice {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.contact-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 30rpx;
}

.contact-btn .iconfont {
  font-size: 40rpx;
  color: #4A90D9;
}

.contact-btn text:last-child {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

.submit-btn {
  flex: 1;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
  margin-left: 20rpx;
}
