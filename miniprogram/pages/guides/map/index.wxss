.map-page {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.filter-bar {
  background-color: #fff;
  position: relative;
  z-index: 10;
}

.type-scroll {
  white-space: nowrap;
  padding: 16rpx 24rpx;
}

.type-item {
  display: inline-block;
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: #666;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  margin-right: 12rpx;
}

.type-item.active {
  background-color: #4A90D9;
  color: #fff;
}

.map {
  flex: 1;
  width: 100%;
}

.poi-list {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  max-height: 50vh;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  overflow-y: auto;
  padding-bottom: env(safe-area-inset-bottom);
}

.poi-item {
  display: flex;
  align-items: flex-start;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.poi-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.poi-icon .iconfont {
  font-size: 32rpx;
  color: #fff;
}

.poi-icon.cowork { background: linear-gradient(135deg, #722ed1 0%, #531dab 100%); }
.poi-icon.stay { background: linear-gradient(135deg, #13c2c2 0%, #08979c 100%); }
.poi-icon.food { background: linear-gradient(135deg, #faad14 0%, #d48806 100%); }
.poi-icon.medical { background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%); }
.poi-icon.transport { background: linear-gradient(135deg, #52c41a 0%, #3da00f 100%); }

.poi-content {
  flex: 1;
}

.poi-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.poi-address {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.poi-tags {
  margin-top: 8rpx;
}

.poi-tags .tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 20rpx;
  color: #4A90D9;
  background-color: rgba(74, 144, 217, 0.1);
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.poi-distance {
  font-size: 24rpx;
  color: #999;
}

.toggle-btn {
  position: absolute;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  width: 80rpx;
  height: 80rpx;
  background-color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

.toggle-btn .iconfont {
  font-size: 40rpx;
  color: #4A90D9;
}
