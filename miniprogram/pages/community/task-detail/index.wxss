.task-detail-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.main-info {
  background-color: #fff;
  padding: 30rpx;
}

.task-category {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  margin-bottom: 16rpx;
}

.task-category.consulting {
  background-color: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
}

.task-category.workshop {
  background-color: rgba(114, 46, 209, 0.1);
  color: #722ed1;
}

.task-category.volunteer {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.task-category.project {
  background-color: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.task-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.task-meta {
  display: flex;
  flex-wrap: wrap;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
  margin-right: 30rpx;
}

.meta-item .iconfont {
  font-size: 32rpx;
  color: #999;
  margin-right: 8rpx;
}

.section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.signup-btn {
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
}

.signup-btn.signed {
  background: #52c41a;
}
