.community-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 24rpx;
}

.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #999;
}

.group-list {
  display: flex;
  flex-direction: column;
}

.group-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.group-item:last-child {
  border-bottom: none;
}

.group-info {
  flex: 1;
}

.group-name {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.group-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.join-btn {
  padding: 12rpx 24rpx;
  background-color: #4A90D9;
  color: #fff;
  font-size: 24rpx;
  border-radius: 30rpx;
}

.task-list {
  display: flex;
  flex-direction: column;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.task-item:last-child {
  border-bottom: none;
}

.task-category {
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.task-category.consulting {
  background-color: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
}

.task-category.workshop {
  background-color: rgba(114, 46, 209, 0.1);
  color: #722ed1;
}

.task-category.volunteer {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.task-category.project {
  background-color: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.task-content {
  flex: 1;
}

.task-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.task-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.task-item .icon-arrow-right {
  color: #ccc;
  font-size: 28rpx;
}

.rules-section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
}

.rules-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.rules-content {
  display: flex;
  flex-direction: column;
}

.rules-content text {
  font-size: 26rpx;
  color: #666;
  line-height: 2;
}

.qr-modal {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 1001;
}

.qr-content {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 560rpx;
}

.qr-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.qr-image {
  width: 400rpx;
  height: 400rpx;
}

.qr-tip {
  font-size: 26rpx;
  color: #999;
  margin-top: 20rpx;
}

.qr-close {
  font-size: 28rpx;
  color: #4A90D9;
  margin-top: 30rpx;
}

.mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}
