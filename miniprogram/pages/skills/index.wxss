.skills-page {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 140rpx;
}

.header {
  background: #fff;
  padding: 40rpx 30rpx;
  padding-top: calc(40rpx + env(safe-area-inset-top));
  border-bottom: 1rpx solid #f0f0f0;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #888;
}

.tabs {
  display: flex;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #888;
  position: relative;
  transition: all 0.2s;
}

.tab-icon {
  width: 36rpx;
  height: 36rpx;
  margin-bottom: 8rpx;
  opacity: 0.6;
}

.tab-item.active {
  color: #4A90D9;
}

.tab-item.active .tab-icon {
  opacity: 1;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 6rpx;
  background: #4A90D9;
  border-radius: 3rpx;
}

.list-content {
  padding: 20rpx 24rpx;
}

.post-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  transition: transform 0.2s, box-shadow 0.2s;
}

.post-card:active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
  margin-right: 16rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.reward-tag {
  padding: 8rpx 18rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.reward-tag.swap {
  background: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
}

.reward-tag.paid {
  background: rgba(250, 140, 22, 0.1);
  color: #fa8c16;
}

.reward-tag.volunteer {
  background: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.post-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.post-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.post-tags {
  margin-bottom: 16rpx;
}

.post-tags .tag {
  display: inline-block;
  padding: 8rpx 18rpx;
  background-color: #f5f7fa;
  color: #666;
  font-size: 22rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.post-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.match-suggest {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #4A90D9;
}

.match-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

.match-btn {
  padding: 14rpx 28rpx;
  background: #4A90D9;
  color: #fff;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(74, 144, 217, 0.3);
  transition: transform 0.2s;
}

.match-btn:active {
  transform: scale(0.95);
}

.publish-btn {
  position: fixed;
  right: 30rpx;
  bottom: calc(180rpx + env(safe-area-inset-bottom));
  width: 108rpx;
  height: 108rpx;
  background: #4A90D9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.4);
  transition: transform 0.2s;
  z-index: 100;
}

.publish-btn:active {
  transform: scale(0.95);
}

.publish-icon {
  width: 52rpx;
  height: 52rpx;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #f0f0f0;
  border-top-color: #4A90D9;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading text {
  color: #999;
  font-size: 26rpx;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
  color: #999;
  font-size: 26rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  opacity: 0.3;
  margin-bottom: 24rpx;
}

.empty-state text {
  color: #999;
  font-size: 28rpx;
}

.empty-tip {
  font-size: 24rpx !important;
  margin-top: 12rpx;
  color: #bbb !important;
}
