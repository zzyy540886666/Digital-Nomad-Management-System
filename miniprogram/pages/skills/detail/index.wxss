.detail-page {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

.post-card {
  background-color: #fff;
  padding: 30rpx;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.time {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.reward-tag {
  padding: 8rpx 20rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.reward-tag.swap {
  background-color: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
}

.reward-tag.paid {
  background-color: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.reward-tag.volunteer {
  background-color: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.post-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.post-content {
  font-size: 30rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 20rpx;
}

.post-tags {
  margin-bottom: 20rpx;
}

.post-tags .tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background-color: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
  font-size: 24rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
}

.post-extra {
  font-size: 26rpx;
  color: #666;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.post-extra .label {
  color: #999;
}

.match-section {
  background-color: #fff;
  margin-top: 20rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.candidate-list {
  display: flex;
  flex-direction: column;
}

.candidate-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.candidate-item:last-child {
  border-bottom: none;
}

.candidate-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.candidate-info {
  flex: 1;
}

.candidate-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.candidate-reason {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.match-score {
  font-size: 28rpx;
  font-weight: bold;
  color: #4A90D9;
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.action-btns {
  display: flex;
  margin-right: 20rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 20rpx;
}

.action-btn .iconfont {
  font-size: 40rpx;
  color: #666;
}

.action-btn text:last-child {
  font-size: 22rpx;
  color: #666;
  margin-top: 4rpx;
}

.action-btn .icon-collected {
  color: #faad14;
}

.match-btn {
  flex: 1;
  background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 40rpx;
  font-size: 30rpx;
}
